# ============================================================
# RustyOnions root .gitignore
# ============================================================

# ------------------------------------------------------------
# OS cruft
# ------------------------------------------------------------
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride

# ------------------------------------------------------------
# Editors / IDE configs
# ------------------------------------------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.iml
*.swp
*.swo

# ------------------------------------------------------------
# Rust / Cargo build artifacts
# ------------------------------------------------------------
/target/
**/target/
Cargo.lock.*.backup

# ------------------------------------------------------------
# Local env/config
# Commit samples/examples only, not live local config.
# ------------------------------------------------------------
.env
.env.*
!.env.example
/config.json
/config.toml
/macronode.toml
*.local.toml
*.local.json
*.local.yaml
*.local.yml

# ------------------------------------------------------------
# Logs / archives / temp files
# ------------------------------------------------------------
logs/
*.log
/gateway.log
*.tgz
*.tar.gz
*.zip
*.bak
*.tmp
*.temp
/out.*
/out.txt
/out.webp

# TCP and Tor server logs
.tcp_server*.log
.tor_server*.log

# ------------------------------------------------------------
# Runtime DBs / sled / local state
# ------------------------------------------------------------
.data/
.data*/
.data-tcp/
**/.data*/
**/.data*/**
snap.*
*.snap.*

db/
**/db/
conf/
**/conf/

/svc-index.db
/svc-index.db/
*.db
*.db/
*.sled
*.sled/

# Local DB/data directories
/data
/data/
/data/ro_db
data/ro_db
data/

# ------------------------------------------------------------
# Runtime storage / buckets / object stores
# ------------------------------------------------------------
/bucket/
/.objects/
.objects/
/.testrun_store/
/.testrun_data/

# ------------------------------------------------------------
# Tests / scratch dirs / run outputs
# ------------------------------------------------------------
/tmp/
tmp/
**/tmp/
scratch/
**/scratch/
.temp/
.testrun.tor.*
.tor_test_logs/
.onions/

# One-off files accidentally created by scripts/tests
/.tmp.post.txt
/hello.txt
/newfile.md
/sample.txt
/ready:true
/services:{index:true}
800ms
/writes

# ------------------------------------------------------------
# Generated repo/code/documentation bundles
# These are for local AI/review workflow, not source truth.
# ------------------------------------------------------------
/CODEBUNDLE.MD
/CODEBUNDLE_RS.md
/ALLCODEBUNDLES.MD
/ALLNOTES.MD
/ALL_DOCS_COMBINED.MD
/workspace_code_dump.md
/refactor_dump/
/refactor_full.md

# ------------------------------------------------------------
# Scratch/archive project areas
# ------------------------------------------------------------
/junkyard/
/experiments/
/artifacts/

# ------------------------------------------------------------
# Blueprint scratch / private internal docs
# ------------------------------------------------------------
/docs/blueprints/DEVELOPER_SUITE_BLUEPRINT.MD/tmp/
/docs/blueprints/DEVELOPER_SUITE_BLUEPRINT.MD

# ------------------------------------------------------------
# Dev TLS materials
# Never commit private keys/certs generated locally.
# ------------------------------------------------------------
testing/tls/*.key
testing/tls/*.csr
testing/tls/*.srl
testing/tls/*.crt
testing/tls/*.pem
/testing/tls/*
*.key
*.csr
*.srl
cert.pem
key.pem

# Demo/test assets that are generated or too large
/testing/tiles/**

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
.venv/
venv/
__pycache__/
*.pyc
*.pyo
.mypy_cache/
.ruff_cache/
.pytest_cache/
.tox/
.hypothesis/

# ------------------------------------------------------------
# Node / JS / TS / Vite
# ------------------------------------------------------------
node_modules/
**/node_modules/
dist/
dist-ssr/
coverage/
.npm/
.yarn/
.pnpm-store/
.vite/
*.tsbuildinfo

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*

# SDK-specific generated JS/TS output
sdk/**/node_modules/
sdk/**/dist/
sdk/**/coverage/
sdk/**/*.log

# ------------------------------------------------------------
# PHP / Composer SDK artifacts
# ------------------------------------------------------------
/vendor/
composer.lock
.phpunit.cache/
.php-cs-fixer.cache
var/cache/
var/cache/phpstan/
var/cache/psalm/

phpunit.xml
phpstan.neon
psalm.xml

sdk/ron-app-sdk-php/vendor/
sdk/ron-app-sdk-php/composer.lock
sdk/ron-app-sdk-php/.php-cs-fixer.cache
sdk/ron-app-sdk-php/var/

# ------------------------------------------------------------
# Java / Gradle / JVM SDK artifacts
# ------------------------------------------------------------
.gradle/
**/.gradle/
**/build/
.classpath
.project
.settings/

# ------------------------------------------------------------
# Swift
# ------------------------------------------------------------
.build/

# ------------------------------------------------------------
# Generic build artifacts
# ------------------------------------------------------------
build/
out/